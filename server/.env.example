# Reference only: Ktor does not auto-load .env files. Export these variables or
# copy the equivalent keys to the root supportdesk.properties file.
SUPPORTDESK_AUTH_SECRET=replace-with-at-least-32-random-characters
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=change-me
SUPPORTDESK_DB_MAX_POOL_SIZE=5
SUPPORTDESK_BOOTSTRAP_DEMO_DATA=false
# SUPPORTDESK_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# SUPPORTDESK_BOOTSTRAP_CLIENT_PASSWORD=replace-with-a-strong-password
