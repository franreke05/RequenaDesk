# Copy this file to `supportdesk.properties` next to the desktop executable
# or place it in `%USERPROFILE%\\.supportdesk\\supportdesk.properties`.
#
# Desktop clients should point to the public HTTPS Ktor backend.
# Example:
# supportdesk.baseUrl=https://crm.example.com

supportdesk.baseUrl=https://your-public-ktor-backend.example.com
